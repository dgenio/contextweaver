[0.0, "o", "$ contextweaver demo --scenario mcp-gateway-full  (60-tool architecture)\r\n"]
[0.8138, "o", "============================================================\r\n"]
[1.1277, "o", "contextweaver demo — mcp-gateway-full scenario (60-tool reference architecture)\r\n"]
[1.4415, "o", "============================================================\r\n"]
[1.7553, "o", "(loading examples/architectures/mcp_context_gateway/main.py — the same script make architectures runs)\r\n"]
[2.0691, "o", "\r\n"]
[2.383, "o", "============================================================================\r\n"]
[2.6968, "o", "contextweaver -- MCP Context Gateway reference architecture\r\n"]
[3.0106, "o", "============================================================================\r\n"]
[3.3245, "o", "(simulated MCP gateway flow using contextweaver primitives)\r\n"]
[3.6383, "o", "\r\n"]
[3.9521, "o", "Loaded catalog: 60 tools across 10 namespaces\r\n"]
[4.266, "o", "\r\n"]
[4.5798, "o", "============================================================================\r\n"]
[4.8936, "o", "[1/5] Route phase — model sees compact ChoiceCards, NOT schemas\r\n"]
[5.2074, "o", "============================================================================\r\n"]
[5.5213, "o", "user typed:    \"Why did customer C-12345's MRR drop last month?\"\r\n"]
[5.8351, "o", "routing query: 'Execute a BigQuery query to find MRR delta rows for customer C-12345'\r\n"]
[6.1489, "o", "(a production agent would LLM-rephrase the user question into the routing query;\r\n"]
[6.4628, "o", " here we hold both explicit so the demo is deterministic.)\r\n"]
[6.7766, "o", "shortlist (5 of 60): ['bigquery.run_query', 'bigquery.dry_run', 'analytics.events.query', 'bigquery.list_datasets', 'analytics.dashboards.get']\r\n"]
[7.0904, "o", "chosen:    bigquery.run_query  (intent='bigquery.run_query')\r\n"]
[7.4043, "o", "\r\n"]
[7.7181, "o", "ChoiceCards rendered to the model (536 chars, NO full schemas):\r\n"]
[8.0319, "o", "[1/5] bigquery.run_query (tool) — Execute a BigQuery SQL query and return rows [bigquery, read, sql] score=2.67\r\n"]
[8.3457, "o", "[2/5] bigquery.dry_run (tool) — Estimate cost of a BigQuery query [bigquery, plan, sql] score=1.65\r\n"]
[8.6596, "o", "[3/5] analytics.events.query (tool) — Query the events table for a customer [analytics, events, read] score=1.21\r\n"]
[8.9734, "o", "[4/5] bigquery.list_datasets (tool) — List BigQuery datasets in a project [bigquery, schema] score=1.17\r\n"]
[9.2872, "o", "[5/5] analytics.dashboards.get (tool) — Fetch a saved analytics dashboard [analytics, dashboards] score=0.00\r\n"]
[9.6011, "o", "\r\n"]
[9.9149, "o", "============================================================================\r\n"]
[10.2287, "o", "[2/5] Call phase — hydrate ONLY the selected tool's schema\r\n"]
[10.5426, "o", "============================================================================\r\n"]
[10.8564, "o", "tool: bigquery.run_query\r\n"]
[11.1702, "o", "hydrated schema for: 'bigquery.run_query'  (854 chars)\r\n"]
[11.484, "o", "hydrated schema for the other 59 tools: 0 chars (skipped)\r\n"]
[11.7979, "o", "\r\n"]
[12.1117, "o", "Schema preview (first 200 chars):\r\n"]
[12.4255, "o", "  '{\\n  \"type\": \"object\",\\n  \"title\": \"bigquery_run_query\",\\n  \"properties\": {\\n    \"sql\": {\\n      \"type\": \"string\",\\n      \"description\": \"Standard-SQL BigQuery query.\"\\n    },\\n    \"project\": {\\n      \"type\": '\r\n"]
[12.7394, "o", "  ...\r\n"]
[13.0532, "o", "\r\n"]
[13.367, "o", "============================================================================\r\n"]
[13.6809, "o", "[3/5] Tool call + [4/5] context firewall\r\n"]
[13.9947, "o", "============================================================================\r\n"]
[14.3085, "o", "called: bigquery.run_query(...)\r\n"]
[14.6223, "o", "raw upstream result: 16,507 chars (MCP wire shape)\r\n"]
[14.9362, "o", "firewall: 16,507 chars  ->  194-char summary  (artifact artifact:result:tc1)\r\n"]
[15.25, "o", "extracted facts (first 3 of 24):\r\n"]
[15.5638, "o", "  - rowset: bigquery.run_query\r\n"]
[15.8777, "o", "  - project: ops-analytics-prod\r\n"]
[16.1915, "o", "  - rows_returned: 90\r\n"]
[16.5053, "o", "\r\n"]
[16.8191, "o", "============================================================================\r\n"]
[17.133, "o", "[5/5] Answer phase — final prompt sees summary + handle, NOT raw rows\r\n"]
[17.4468, "o", "============================================================================\r\n"]
[17.7606, "o", "answer prompt: included=3  tokens=142\r\n"]
[18.0745, "o", "final prompt length: 645 chars\r\n"]
[18.3883, "o", "contains raw rowset? no\r\n"]
[18.7021, "o", "contains artifact handle? yes\r\n"]
[19.016, "o", "contains durable fact?    yes\r\n"]
[19.3298, "o", "contains user query?      yes\r\n"]
[19.6436, "o", "contains tool call?       yes\r\n"]
[19.9574, "o", "\r\n"]
[20.2713, "o", "--- Final answer-phase prompt ---\r\n"]
[20.5851, "o", "[FACTS]\r\n"]
[20.8989, "o", "- customer.C-12345.plan_change: growth -> starter (self-serve, day 47, -$450 MRR)\r\n"]
[21.2128, "o", "\r\n"]
[21.5266, "o", "[TOOL RESULT [artifact:artifact:result:tc1]]\r\n"]
[21.8404, "o", "rowset: bigquery.run_query\r\n"]
[22.1543, "o", "project: ops-analytics-prod\r\n"]
[22.4681, "o", "rows_returned: 90\r\n"]
[22.7819, "o", "schema: date STRING, customer_id STRING, plan STRING, mrr_delta_usd INT64, reason_code STRING, actor STRING, notes STRING\r\n"]
[23.0957, "o", "\r\n"]
[23.4096, "o", "[USER]\r\n"]
[23.7234, "o", "Why did customer C-12345's MRR drop last month?\r\n"]
[24.0372, "o", "\r\n"]
[24.3511, "o", "[TOOL CALL]\r\n"]
[24.6649, "o", "bigquery.run_query({\"sql\":\"SELECT date, plan, mrr_delta_usd, reason_code, actor, notes FROM `ops-analytics-prod.billing.mrr_changes` WHERE customer_id = 'C-12345' AND date BETWEEN '2026-02-01' AND '2026-04-30' ORDER BY date\",\"max_results\":1000})\r\n"]
[24.9787, "o", "--- end prompt ---\r\n"]
[25.2926, "o", "\r\n"]
[25.6064, "o", "============================================================================\r\n"]
