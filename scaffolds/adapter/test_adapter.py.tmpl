"""Tests for the {{Adapter Display Name}} adapter.

These tests should use local fakes and must not call a live provider API.
"""

from __future__ import annotations

from dataclasses import dataclass

from contextweaver.adapters.{{adapter_name}} import (
    from_{{adapter_name}}_history,
    from_{{adapter_name}}_tools,
)
from contextweaver.types import ItemKind


@dataclass
class FakeTool:
    name: str
    description: str


@dataclass
class FakeMessage:
    role: str
    content: str


def test_from_{{adapter_name}}_tools_converts_fake_tool() -> None:
    items = from_{{adapter_name}}_tools(
        [FakeTool(name="search", description="Search local documents")],
        namespace="fake",
    )

    assert len(items) == 1
    assert items[0].id == "fake.search"
    assert items[0].kind == "tool"
    assert items[0].name == "search"
    assert items[0].description == "Search local documents"
    assert items[0].metadata["adapter"] == "{{adapter_name}}"


def test_from_{{adapter_name}}_tools_accepts_mapping() -> None:
    items = from_{{adapter_name}}_tools([
        {"name": "lookup", "description": "Look up a local record"},
    ])

    assert items[0].id == "{{adapter_name}}.lookup"


def test_from_{{adapter_name}}_tools_rejects_missing_name() -> None:
    try:
        from_{{adapter_name}}_tools([{"description": "missing name"}])
    except ValueError as exc:
        assert "missing a name" in str(exc)
    else:  # pragma: no cover - clearer failure message
        raise AssertionError("expected missing tool name to raise ValueError")


def test_from_{{adapter_name}}_history_converts_fake_messages() -> None:
    items = from_{{adapter_name}}_history(
        [
            FakeMessage(role="user", content="hello"),
            FakeMessage(role="assistant", content="hi"),
        ]
    )

    assert [item.kind for item in items] == [ItemKind.user_turn, ItemKind.assistant_turn]
    assert [item.text for item in items] == ["hello", "hi"]
    assert items[0].metadata["adapter"] == "{{adapter_name}}"
